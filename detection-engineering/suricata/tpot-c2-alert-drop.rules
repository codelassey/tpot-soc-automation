# CVE-2024-4577 PHP-CGI Worm C2 
alert http $HOME_NET any -> any any (msg:"TPOT CVE-2024-4577 Worm C2 Contact 14.46.136.77"; http.host; content:"14.46.136.77"; sid:9100001; rev:1;)
alert http $HOME_NET any -> any any (msg:"TPOT CVE-2024-4577 Worm C2 Contact 125.135.169.171"; http.host; content:"125.135.169.171"; sid:9100002; rev:1;)
alert http $HOME_NET any -> any any (msg:"TPOT CVE-2024-4577 Worm C2 Contact 121.176.14.102"; http.host; content:"121.176.14.102"; sid:9100003; rev:1;)
alert http any any -> any any (msg:"TPOT CVE-2024-4577 Selfrep Payload in HTTP Body"; http.request_body; content:"cve_2024_4577.selfrep"; nocase; sid:9100004; rev:1;)
alert http any any -> any any (msg:"TPOT CVE-2024-4577 apache.selfrep Worm Stage 2"; http.request_body; content:"apache.selfrep"; nocase; sid:9100005; rev:1;)
alert http any any -> any any (msg:"TPOT CVE-2024-4577 Worm Delivery Endpoint /sh"; http.uri; content:"/sh"; startswith; endswith; sid:9100006; rev:1;)
drop ip $HOME_NET any -> 14.46.136.77 any (msg:"TPOT DROP CVE-2024-4577 C2 Outbound"; sid:9100007; rev:1;)
drop ip $HOME_NET any -> 125.135.169.171 any (msg:"TPOT DROP CVE-2024-4577 C2 Outbound"; sid:9100008; rev:1;)
drop ip $HOME_NET any -> 121.176.14.102 any (msg:"TPOT DROP CVE-2024-4577 C2 Outbound"; sid:9100009; rev:1;)

